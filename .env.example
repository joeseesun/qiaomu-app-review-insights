# Qiaomu LLM / DeepSeek flash 配置（必需）
# 密钥不要提交到仓库；本机可从 qiaomu-llm Keychain 引用导出到运行环境。
QIAOMU_LLM_API_KEY=your_deepseek_api_key_here
QIAOMU_LLM_BASE_URL=https://api.deepseek.com/v1
QIAOMU_LLM_MODEL=deepseek-v4-flash

# 兼容旧后台分析接口
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-v4-flash

# Public Qiaomu analytics tracker id; safe to expose in HTML.
NEXT_PUBLIC_UMAMI_WEBSITE_ID=
NEXT_PUBLIC_UMAMI_DOMAIN=appreview.qiaomu.ai
NEXT_PUBLIC_SITE_URL=https://appreview.qiaomu.ai

# SEO page cache. Leave empty to use src/data/app-cache.
APP_REVIEW_CACHE_DIR=

# Data Storage Configuration
# Set to 'local' for JSON file storage, 'vercel-kv' for Vercel KV, 'supabase' for Supabase
STORAGE_TYPE=local

# Vercel KV Configuration (optional)
KV_REST_API_URL=
KV_REST_API_TOKEN=

# Supabase Configuration (optional)
SUPABASE_URL=
SUPABASE_ANON_KEY=

# Cron Job Secret (for security)
CRON_SECRET=your_random_secret_here
